# Database Configuration
DATABASE_URL="postgresql://postgres@localhost:5432/ai_interviewer"

# API Keys (Set up your preferred models below)
OPENAI_KEY="YOUR_OPENAI_API_KEY_HERE"

# =========================================================================
# FREE & LOCAL LLM MODELS (Ollama, Gemini, Groq, OpenRouter)
# =========================================================================
#
# Option A: Local Ollama (100% free and offline)
# 1. Download & install Ollama from https://ollama.com
# 2. Run: ollama pull qwen2.5:3b (or any small model like llama3, mistral, gemma)
# 3. Ensure Ollama is running. The server will detect it automatically!
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="qwen2.5:3b"  # If left empty, will automatically use the first model pulled
#
# Option B: Google Gemini 1.5 Flash (Generous free tier: 15 RPM)
# 1. Get a free API key instantly from Google AI Studio: https://aistudio.google.com/
# 2. Uncomment the line below and insert your API key:
# GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
#
# Option C: Groq Cloud (Free high-speed tier)
# 1. Create a free account and get an API key: https://console.groq.com/
# 2. Uncomment the line below and insert your API key:
# GROQ_API_KEY="YOUR_GROQ_API_KEY"
#
# Option D: OpenRouter (Free model router)
# 1. Register a free account: https://openrouter.ai/
# 2. Generate a key, uncomment below, and insert your API key:
# OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
# =========================================================================
